<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background layers -->
    <Color x:Key="BackgroundDeepColor">#FF0A0E1A</Color>
    <Color x:Key="BackgroundColor">#FF0D1526</Color>
    <Color x:Key="BackgroundElevatedColor">#FF111D33</Color>
    <Color x:Key="SurfaceColor">#FF1A2940</Color>

    <!-- Brand blue -->
    <Color x:Key="AccentColor">#FF2D6BE4</Color>
    <Color x:Key="AccentBrightColor">#FF4A90F5</Color>
    <Color x:Key="AccentDimColor">#FF1A4299</Color>

    <!-- Warning / danger -->
    <Color x:Key="WarningColor">#FFE8A020</Color>
    <Color x:Key="DangerColor">#FFE84040</Color>
    <Color x:Key="SuccessColor">#FF30C060</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#FFF0F4FF</Color>
    <Color x:Key="TextSecondaryColor">#FF8A9BBF</Color>
    <Color x:Key="TextMutedColor">#FF4A5A7A</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BackgroundDeepBrush" Color="{StaticResource BackgroundDeepColor}" />
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="BackgroundElevatedBrush" Color="{StaticResource BackgroundElevatedColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentBrightBrush" Color="{StaticResource AccentBrightColor}" />
    <SolidColorBrush x:Key="AccentDimBrush" Color="{StaticResource AccentDimColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />

    <!-- Lock overlay gradient -->
    <LinearGradientBrush x:Key="LockOverlayGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF060B14" Offset="0.0" />
        <GradientStop Color="#FF0A1528" Offset="0.5" />
        <GradientStop Color="#FF0D1E3A" Offset="1.0" />
    </LinearGradientBrush>

</ResourceDictionary>
