<Window x:Class="WaterCueWindows.Views.WarningWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="420"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False">

    <Border Style="{StaticResource CardBorderStyle}"
            Padding="0"
            MouseDown="Border_MouseDown">
        <Grid>
            <Border Background="{StaticResource HeroPanelBrush}"
                    CornerRadius="20,20,0,0"
                    Padding="22,20,22,18">
                <StackPanel>
                    <TextBlock Text="WaterCue"
                               Style="{StaticResource SectionCaptionTextStyle}"
                               Foreground="{StaticResource AccentBrush}" />
                    <TextBlock Text="Hora de beber água"
                               Style="{StaticResource WindowTitleTextStyle}"
                               FontSize="24"
                               Margin="0,8,0,0" />
                    <TextBlock x:Name="CountdownLabel"
                               Style="{StaticResource BodyTextStyle}"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <StackPanel Margin="22,124,22,22">
                <Border Background="{StaticResource BackgroundBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="14"
                        Margin="0,0,0,16">
                    <TextBlock Text="Beba agora para evitar o bloqueio. Se não der, você pode adiar por cinco minutos."
                               Style="{StaticResource BodyTextStyle}"
                               TextWrapping="Wrap" />
                </Border>

                <Button x:Name="DrinkButton"
                        Content="Já bebi"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,0,0,8"
                        Click="DrinkButton_Click"
                        Cursor="Hand" />

                <Button x:Name="SnoozeButton"
                        Content="Adiar 5 minutos"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="SnoozeButton_Click"
                        Cursor="Hand" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
