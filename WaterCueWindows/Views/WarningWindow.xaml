<Window x:Class="WaterCueWindows.Views.WarningWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="380"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False">

    <Border Style="{StaticResource CardBorderStyle}"
            Padding="0"
            MouseDown="Border_MouseDown">
        <Border.Effect>
            <DropShadowEffect Color="#22000000"
                              BlurRadius="28"
                              ShadowDepth="12"
                              Opacity="0.18" />
        </Border.Effect>

        <Grid>
            <Border Background="{StaticResource AccentDimBrush}"
                    CornerRadius="14,14,0,0"
                    Padding="20,18,20,16">
                <StackPanel>
                    <TextBlock Text="WaterCue"
                               Style="{StaticResource SectionCaptionTextStyle}"
                               Foreground="{StaticResource AccentBrush}" />
                    <TextBlock Text="Hora de beber agua"
                               Style="{StaticResource WindowTitleTextStyle}"
                               FontSize="23"
                               Margin="0,6,0,0" />
                    <TextBlock x:Name="CountdownLabel"
                               Style="{StaticResource BodyTextStyle}"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <StackPanel Margin="20,112,20,20">
                <Border Background="{StaticResource BackgroundBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="14"
                        Margin="0,0,0,16">
                    <TextBlock Text="Beba agora para evitar o bloqueio. Se nao der, voce pode adiar por cinco minutos."
                               Style="{StaticResource BodyTextStyle}"
                               TextWrapping="Wrap" />
                </Border>

                <Button x:Name="DrinkButton"
                        Content="Ja bebi"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,0,0,8"
                        Click="DrinkButton_Click"
                        Cursor="Hand" />

                <Button x:Name="SnoozeButton"
                        Content="Adiar 5 minutos"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="SnoozeButton_Click"
                        Cursor="Hand" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
