<Window x:Class="WaterCueWindows.Views.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WaterCue"
        Width="960"
        Height="680"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Background="{StaticResource WindowBackgroundBrush}">

    <Grid Margin="24">
        <Border Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource AccentPanelBrush}"
                        CornerRadius="20,0,0,20"
                        Padding="28">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Background="#22FFFFFF"
                                BorderBrush="#33FFFFFF"
                                BorderThickness="1"
                                CornerRadius="999"
                                Padding="12,6"
                                HorizontalAlignment="Left">
                            <TextBlock Text="WaterCue"
                                       Foreground="White"
                                       FontSize="11"
                                       FontWeight="SemiBold" />
                        </Border>

                        <StackPanel Grid.Row="1"
                                    Margin="0,22,0,0">
                            <TextBlock Text="Configuração inicial"
                                       FontFamily="Segoe UI Variable Display, Segoe UI Variable, Segoe UI"
                                       FontSize="30"
                                       FontWeight="SemiBold"
                                       Foreground="White" />
                            <TextBlock Text="Tudo o que você precisa para deixar o WaterCue pronto no Windows."
                                       FontSize="14"
                                       Foreground="#DDF7FBFF"
                                       Margin="0,10,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Grid.Row="2"
                                    Margin="0,28,0,0">
                            <Border Background="#1AFFFFFF"
                                    BorderBrush="#26FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Padding="16"
                                    Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="O que será configurado"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="White" />
                                    <TextBlock Text="Câmera, IA, 4 métricas de hidratação e o comportamento do app."
                                               FontSize="13"
                                               Foreground="#DDEAF4FF"
                                               Margin="0,8,0,0"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Background="#14FFFFFF"
                                    BorderBrush="#22FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Visual de desktop"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="White" />
                                    <TextBlock Text="O fluxo foi simplificado para o Windows: menos fricção e foco nas decisões certas."
                                               FontSize="13"
                                               Foreground="#DDEAF4FF"
                                               Margin="0,8,0,0"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <TextBlock Grid.Row="3"
                                   Text="Versão para Windows"
                                   FontSize="12"
                                   Foreground="#CDE7F4FF"
                                   HorizontalAlignment="Left" />
                    </Grid>
                </Border>

                <Grid Grid.Column="1"
                      Margin="30,26,30,26">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <ItemsControl x:Name="ProgressDots"
                                  Grid.Row="0"
                                  HorizontalAlignment="Left"
                                  Margin="0,0,0,18">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="StepContent"
                                    MaxWidth="500"
                                    Margin="0,4,0,4" />
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
