<Window x:Class="WaterCueWindows.Views.StatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="WaterCue — Estatísticas"
        Width="380" Height="360"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        WindowStartupLocation="CenterScreen">

    <Window.Background>
        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
            <GradientStop Color="#FF0D1117" Offset="0"/>
            <GradientStop Color="#FF0D1B2E" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <StackPanel Margin="24">

        <!-- Title -->
        <TextBlock Text="Hidratação"
                   FontFamily="Segoe UI Variable, Segoe UI"
                   FontSize="20" FontWeight="Bold"
                   Foreground="White"
                   Margin="0,0,0,16"/>

        <!-- Today card -->
        <Border x:Name="TodayCard"
                Background="#1A111D33"
                CornerRadius="10"
                Padding="14,12"
                Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="💧  " FontSize="14"/>
                    <TextBlock Text="Hoje"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
                <TextBlock x:Name="TodayLabel"
                           Grid.Column="1"
                           FontSize="13"
                           FontFamily="Consolas, Courier New"
                           Foreground="White"/>
            </Grid>
        </Border>

        <!-- Streak card -->
        <Border Background="#1A111D33"
                CornerRadius="10"
                Padding="14,12"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🔥  " FontSize="14"/>
                    <TextBlock Text="Sequência"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
                <TextBlock x:Name="StreakLabel"
                           Grid.Column="1"
                           FontSize="13"
                           FontFamily="Consolas, Courier New"
                           Foreground="{StaticResource WarningBrush}"/>
            </Grid>
        </Border>

        <!-- Weekly chart -->
        <TextBlock Text="Últimos 7 dias"
                   FontSize="12"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   Margin="0,0,0,8"/>

        <oxy:PlotView x:Name="WeeklyChart"
                      Height="130"
                      Background="Transparent"
                      BorderThickness="0"/>

    </StackPanel>
</Window>
