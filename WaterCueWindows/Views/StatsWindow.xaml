<Window x:Class="WaterCueWindows.Views.StatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="WaterCue - Estatísticas"
        Width="460"
        Height="500"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource CardBorderStyle}"
                Background="{StaticResource AccentDimBrush}"
                Padding="20,18"
                Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="Hidratacao"
                           Style="{StaticResource WindowTitleTextStyle}" />
                <TextBlock Text="Resumo rapido da sua rotina nos ultimos dias."
                           Style="{StaticResource BodyTextStyle}"
                           Margin="0,6,0,0" />
            </StackPanel>
        </Border>

        <Border x:Name="TodayCard"
                Grid.Row="1"
                Style="{StaticResource CardBorderStyle}"
                Padding="16,14"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Hoje"
                               Style="{StaticResource SectionCaptionTextStyle}" />
                    <TextBlock Text="Consumo validado hoje"
                               Style="{StaticResource BodyTextStyle}"
                               Margin="0,4,0,0" />
                </StackPanel>
                <TextBlock x:Name="TodayLabel"
                           Grid.Column="1"
                           VerticalAlignment="Center"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource CardBorderStyle}"
                Padding="16,14"
                Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Sequencia"
                               Style="{StaticResource SectionCaptionTextStyle}" />
                    <TextBlock Text="Dias batendo sua meta"
                               Style="{StaticResource BodyTextStyle}"
                               Margin="0,4,0,0" />
                </StackPanel>
                <TextBlock x:Name="StreakLabel"
                           Grid.Column="1"
                           VerticalAlignment="Center"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource WarningBrush}" />
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Style="{StaticResource CardBorderStyle}"
                Padding="16">
            <StackPanel>
                <TextBlock Text="Ultimos 7 dias"
                           Style="{StaticResource SectionCaptionTextStyle}" />
                <TextBlock Text="Visual rapido do seu ritmo recente."
                           Style="{StaticResource BodyTextStyle}"
                           Margin="0,4,0,12" />
                <oxy:PlotView x:Name="WeeklyChart"
                              Height="230"
                              Background="Transparent"
                              BorderThickness="0" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
