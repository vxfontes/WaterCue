<Window x:Class="WaterCueWindows.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WaterCue - Configurações"
        Width="520"
        Height="680"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource CardBorderStyle}"
                Background="{StaticResource AccentDimBrush}"
                Padding="22,18"
                Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Configurações"
                           Style="{StaticResource WindowTitleTextStyle}" />
                <TextBlock Text="Ajuste câmera, horários, Groq e comportamento do app no Windows."
                           Style="{StaticResource BodyTextStyle}"
                           Margin="0,6,0,0" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="SettingsPanel" />
        </ScrollViewer>

        <Grid Grid.Row="2"
              Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="140" />
            </Grid.ColumnDefinitions>

            <Button x:Name="CancelBtn"
                    Grid.Column="0"
                    Content="Cancelar"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="Cancel_Click" />

            <Button x:Name="SaveBtn"
                    Grid.Column="2"
                    Content="Salvar"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="Save_Click" />
        </Grid>
    </Grid>
</Window>
