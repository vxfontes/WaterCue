<Window x:Class="WaterCueWindows.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WaterCue"
        Width="760"
        Height="720"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="240" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource CardBorderStyle}"
                    Background="{StaticResource HeroPanelBrush}"
                    Padding="24,22"
                    Margin="0,0,14,0">
                <StackPanel>
                    <TextBlock Text="Preferências do WaterCue"
                               Style="{StaticResource WindowTitleTextStyle}" />
                    <TextBlock Text="Ajuste câmera, horários, IA e comportamento do aplicativo."
                               Style="{StaticResource BodyTextStyle}"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource CardBorderStyle}"
                    Padding="18">
                <StackPanel>
                    <TextBlock Text="Resumo"
                               Style="{StaticResource SectionCaptionTextStyle}" />
                    <TextBlock Text="Tudo aqui afeta o próximo ciclo de bloqueio."
                               Style="{StaticResource BodyTextStyle}"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="SettingsPanel" />
        </ScrollViewer>

        <Grid Grid.Row="2"
              Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="140" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <Button x:Name="CancelBtn"
                    Grid.Column="0"
                    Content="Cancelar"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="Cancel_Click" />

            <Button x:Name="SaveBtn"
                    Grid.Column="2"
                    Content="Salvar"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="Save_Click" />
        </Grid>
    </Grid>
</Window>
