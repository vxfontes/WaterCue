<Window x:Class="WaterCueWindows.Views.LockOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        Topmost="True"
        ShowInTaskbar="False"
        Background="{StaticResource BackgroundDeepBrush}">

    <Grid>
        <!-- Background gradient -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Color="#FF060B14" Offset="0"/>
                <GradientStop Color="#FF0A1528" Offset="0.5"/>
                <GradientStop Color="#FF0D1E3A" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Primary screen content -->
        <Grid x:Name="PrimaryContent" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="48,0,48,32">
                <TextBlock Text="💧"
                           FontSize="56"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"/>
                <TextBlock Text="Hora de beber água!"
                           FontFamily="Segoe UI Variable, Segoe UI"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                <TextBlock Text="Segure seu copo ou garrafa e tire uma foto para desbloquear."
                           FontFamily="Segoe UI Variable, Segoe UI"
                           FontSize="14"
                           Foreground="#8AFFFFFF"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           MaxWidth="420"/>
            </StackPanel>

            <!-- Camera / Validation area -->
            <Grid Grid.Row="2" x:Name="CameraArea" HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Normal camera view -->
                <StackPanel x:Name="CameraPanel" HorizontalAlignment="Center">
                    <Border CornerRadius="20"
                            ClipToBounds="True"
                            Width="480"
                            Height="346"
                            Margin="0,0,0,20">
                        <Border.Effect>
                            <DropShadowEffect x:Name="CameraGlow" Color="#FF27B7F5"
                                             BlurRadius="32" ShadowDepth="0" Opacity="0"/>
                        </Border.Effect>
                        <Grid>
                            <!-- Camera frame -->
                            <Image x:Name="CameraPreview"
                                   Stretch="UniformToFill"/>
                            <!-- No-camera overlay -->
                            <Border x:Name="NoCameraOverlay"
                                    Background="#BF000000"
                                    CornerRadius="20"
                                    Visibility="Visible">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock x:Name="CameraStatusIcon"
                                               Text="📷"
                                               FontSize="44"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,12"/>
                                    <TextBlock x:Name="CameraStatusLabel"
                                               Text="Iniciando câmera…"
                                               FontSize="14"
                                               Foreground="#99FFFFFF"
                                               HorizontalAlignment="Center"/>
                                    <Button x:Name="RetryButton"
                                            Content="Tentar novamente"
                                            Margin="0,12,0,0"
                                            Visibility="Collapsed"
                                            Click="RetryButton_Click"
                                            HorizontalAlignment="Center">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="Transparent"
                                                        BorderBrush="#33FFFFFF"
                                                        BorderThickness="1"
                                                        CornerRadius="6"
                                                        Padding="16,6">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <!-- Border ring -->
                            <Border CornerRadius="20"
                                    BorderThickness="1.5">
                                <Border.BorderBrush>
                                    <SolidColorBrush x:Name="CameraRingBrush" Color="#1FFFFFFF"/>
                                </Border.BorderBrush>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Capture button -->
                    <Button x:Name="CaptureButton"
                            Click="CaptureButton_Click"
                            HorizontalAlignment="Center"
                            IsEnabled="False"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="CaptureBorder" CornerRadius="24" Padding="44,15">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#FF8CDBFF" Offset="0"/>
                                            <GradientStop Color="#FF33A6FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="CaptureBorder" Property="Background">
                                            <Setter.Value>
                                                <SolidColorBrush Color="#14FFFFFF"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock x:Name="CaptureButtonLabel"
                                   Text="Aguardando câmera…"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#66FFFFFF"/>
                    </Button>
                </StackPanel>

                <!-- Validating spinner -->
                <StackPanel x:Name="ValidatingPanel"
                            Visibility="Collapsed"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True"
                                 Width="200"
                                 Height="4"
                                 Margin="0,0,0,16"
                                 Foreground="{StaticResource AccentBrightBrush}"/>
                    <TextBlock Text="Analisando foto…"
                               FontSize="16"
                               Foreground="#99FFFFFF"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Validation failed -->
                <StackPanel x:Name="FailedPanel"
                            Visibility="Collapsed"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="440">
                    <TextBlock Text="😅"
                               FontSize="48"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>
                    <TextBlock x:Name="FailedReasonLabel"
                               FontSize="15"
                               Foreground="#CCFFFFFF"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,0,0,16"/>
                    <Button Content="Tentar de novo"
                            Click="RetryCapture_Click"
                            HorizontalAlignment="Center"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{StaticResource AccentBrush}"
                                        CornerRadius="8"
                                        Padding="28,10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Emergency area -->
            <StackPanel Grid.Row="3"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,36">
                <TextBlock x:Name="EmergencyCountdownLabel"
                           FontSize="12"
                           Foreground="#66FFFFFF"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                <Button x:Name="EmergencyButton"
                        Visibility="Collapsed"
                        Click="EmergencyButton_Click"
                        HorizontalAlignment="Center"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#26FFFFFF"
                                    BorderBrush="#7FFFFF00"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="20,10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠  " FontSize="14" Foreground="#FFFF00"/>
                        <TextBlock Text="Desbloquear (emergência)"
                                   FontSize="14"
                                   Foreground="White"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Secondary screen content -->
        <StackPanel x:Name="SecondaryContent"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <TextBlock Text="💧"
                       FontSize="48"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16"
                       Opacity="0.7"/>
            <TextBlock Text="Vá para o monitor principal"
                       FontFamily="Segoe UI Variable, Segoe UI"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>
            <TextBlock Text="Tire a foto no outro monitor para desbloquear."
                       FontSize="14"
                       Foreground="#80FFFFFF"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
