<Window x:Class="WaterCueWindows.Views.LockOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        Topmost="True"
        ShowInTaskbar="False"
        Background="{StaticResource OverlayBackgroundBrush}">

    <Grid Background="{StaticResource LockOverlayGradientBrush}">
        <Grid x:Name="PrimaryContent"
              Visibility="Collapsed"
              Margin="52">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#14FFFFFF"
                    BorderBrush="#1FFFFFFF"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="24,20"
                    Margin="0,0,0,26">
                <StackPanel>
                    <TextBlock Text="WaterCue"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrightBrush}" />
                    <TextBlock Text="Bloqueio por hidratacao"
                               FontFamily="Segoe UI Variable Display, Segoe UI Variable, Segoe UI"
                               FontSize="30"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource OverlayTextBrush}"
                               Margin="0,6,0,0" />
                    <TextBlock Text="Segure seu copo ou garrafa e tire uma foto para desbloquear."
                               FontSize="14"
                               Foreground="{StaticResource OverlayMutedBrush}"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               MaxWidth="520" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="1"
                  x:Name="CameraArea"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
                <StackPanel x:Name="CameraPanel"
                            HorizontalAlignment="Center">
                    <Border CornerRadius="22"
                            ClipToBounds="True"
                            Width="560"
                            Height="390"
                            Margin="0,0,0,18"
                            Background="{StaticResource OverlaySurfaceBrush}"
                            BorderBrush="{StaticResource OverlayBorderBrush}"
                            BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect x:Name="CameraGlow"
                                              Color="#FF3AA0F3"
                                              BlurRadius="28"
                                              ShadowDepth="0"
                                              Opacity="0" />
                        </Border.Effect>
                        <Grid>
                            <Image x:Name="CameraPreview"
                                   Stretch="UniformToFill" />
                            <Border x:Name="NoCameraOverlay"
                                    Background="#CC0F1727"
                                    CornerRadius="22"
                                    Visibility="Visible">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Margin="24">
                                    <TextBlock x:Name="CameraStatusIcon"
                                               Text="CAM"
                                               FontSize="24"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource OverlayTextBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,10" />
                                    <TextBlock x:Name="CameraStatusLabel"
                                               Text="Iniciando camera..."
                                               FontSize="14"
                                               Foreground="{StaticResource OverlayMutedBrush}"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center" />
                                    <Button x:Name="RetryButton"
                                            Content="Tentar novamente"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="0,14,0,0"
                                            Visibility="Collapsed"
                                            Click="RetryButton_Click"
                                            HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border CornerRadius="22"
                                    BorderThickness="1.5">
                                <Border.BorderBrush>
                                    <SolidColorBrush x:Name="CameraRingBrush"
                                                     Color="#24FFFFFF" />
                                </Border.BorderBrush>
                            </Border>
                        </Grid>
                    </Border>

                    <Button x:Name="CaptureButton"
                            Click="CaptureButton_Click"
                            HorizontalAlignment="Center"
                            IsEnabled="False"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="240"
                            Cursor="Hand">
                        <TextBlock x:Name="CaptureButtonLabel"
                                   Text="Aguardando camera..."
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="White" />
                    </Button>
                </StackPanel>

                <StackPanel x:Name="ValidatingPanel"
                            Visibility="Collapsed"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Border Background="#14FFFFFF"
                            BorderBrush="#1FFFFFFF"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="26">
                        <StackPanel>
                            <ProgressBar IsIndeterminate="True"
                                         Width="240"
                                         Height="4"
                                         Margin="0,0,0,14"
                                         Foreground="{StaticResource AccentBrightBrush}" />
                            <TextBlock Text="Analisando foto..."
                                       FontSize="16"
                                       Foreground="{StaticResource OverlayTextBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel x:Name="FailedPanel"
                            Visibility="Collapsed"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="460">
                    <Border Background="#14FFFFFF"
                            BorderBrush="#1FFFFFFF"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="28">
                        <StackPanel>
                            <TextBlock Text="Validacao falhou"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource OverlayTextBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,8" />
                            <TextBlock x:Name="FailedReasonLabel"
                                       FontSize="15"
                                       Foreground="{StaticResource OverlayMutedBrush}"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Margin="0,0,0,18" />
                            <Button Content="Tentar de novo"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="RetryCapture_Click"
                                    HorizontalAlignment="Center"
                                    Width="180"
                                    Cursor="Hand" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2"
                        HorizontalAlignment="Center"
                        Margin="0,24,0,0">
                <TextBlock x:Name="EmergencyCountdownLabel"
                           FontSize="12"
                           Foreground="{StaticResource OverlayMutedBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10" />
                <Button x:Name="EmergencyButton"
                        Visibility="Collapsed"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="EmergencyButton_Click"
                        HorizontalAlignment="Center"
                        Cursor="Hand"
                        Content="Desbloquear em emergencia" />
            </StackPanel>
        </Grid>

        <StackPanel x:Name="SecondaryContent"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="480">
            <Border Background="#14FFFFFF"
                    BorderBrush="#1FFFFFFF"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="28">
                <StackPanel>
                    <TextBlock Text="Volte para o monitor principal"
                               FontFamily="Segoe UI Variable Display, Segoe UI Variable, Segoe UI"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource OverlayTextBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="A validacao da foto acontece apenas na tela principal."
                               FontSize="14"
                               Foreground="{StaticResource OverlayMutedBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,10,0,0" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>
